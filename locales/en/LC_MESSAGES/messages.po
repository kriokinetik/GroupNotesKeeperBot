msgid "system_start_message"
msgstr ""
"<b>Hello!</b>\n"
"\n"
"I help organize notes by groups: you can create groups, add entries, and quickly find the information you need.\n"
"\n"
"To get started, open group management with /groups and then add entries with /add.\n"
"\n"
"A full list of features is available via /help."

msgid "system_help_message"
msgstr ""
"<b>Command Reference</b>\n"
"\n"
"/start - show a short introduction.\n"
"/help - show this help message.\n"
"/groups - create, view, or delete groups.\n"
"/add - add an entry to a selected group.\n"
"/history - open the entry history for a group.\n"
"/delete - delete a replied message.\n"
"/admin - view, add, or remove chat admins."

